  "created": "2026-01-29T00:00:00Z",
  "modified": "2026-01-29T00:00:00Z",
  "created_by_ref": "identity--clearfake-community",
  "name": "ClearFake",
  "is_family": true,
  "malware_types": ["downloader", "loader"],
  "description": "ClearFake is a malicious JavaScript-based delivery framework injected into compromised legitimate websites. It profiles victims, retrieves staged configuration data from remote resources (including web services such as smart contract-based infrastructure like Binance Smart Chain), and facilitates user-assisted execution of downstream payloads. It does not act as a standalone malware but as a modular staging framework enabling dynamic payload delivery.",
  "labels": ["delivery-framework", "javascript", "multi-stage"]
},
{
  "type": "malware",
  "spec_version": "2.1",
  "id": "malware--amadey",
  "created": "2026-01-29T00:00:00Z",
  "modified": "2026-01-29T00:00:00Z",
  "created_by_ref": "identity--clearfake-community",
  "name": "Amadey",
  "is_family": true,
  "malware_types": ["trojan", "downloader"],
  "description": "Amadey is a modular malware payload delivered downstream of ClearFake infections. It supports additional payload delivery, credential harvesting, persistence mechanisms, and command-and-control communication."
},
{
  "type": "report",
  "spec_version": "2.1",
  "id": "report--clearfake-campaign",
  "created": "2026-01-29T00:00:00Z",
  "modified": "2026-01-29T00:00:00Z",
  "created_by_ref": "identity--clearfake-community",
  "name": "ClearFake Campaign – User-Assisted Drive-by Infection Framework",
  "description": "This report documents the ClearFake campaign, which leverages malicious JavaScript injected into compromised legitimate websites. The framework retrieves staged configuration data from remote resources, including web services and smart contract-based infrastructure, to dynamically control payload delivery. It relies on user-assisted execution to transition from browser-based activity to endpoint compromise and deliver multiple downstream payloads such as Amadey.",
  "report_types": ["threat-report"],
  "published": "2026-01-29T00:00:00Z",
